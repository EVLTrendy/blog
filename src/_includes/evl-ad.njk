<div class="evl-ad-instance" style="display: none; margin-bottom: 25px;">
    <div class="evl-tile-wrap"></div>
</div>

{# Only load the script once #}
{% if not evlAdScriptLoaded %}
<style>
.evl-tile {
    position: relative;
    padding: 14px 16px;
    border-radius: 14px;
    background: #111318;
    border: 1px solid rgba(255, 255, 255, 0.05);
    font-family: 'Inter', -apple-system, sans-serif;
    cursor: pointer;
    transition: border-color 0.25s ease, box-shadow 0.25s ease;
    opacity: 0;
    transform: translateY(4px);
    animation: evlTileFadeIn 0.4s ease 0.1s forwards;
    overflow: hidden;
}
@keyframes evlTileFadeIn {
    to { opacity: 1; transform: translateY(0); }
}
.evl-tile:hover {
    border-color: var(--evl-accent, rgba(255,255,255,0.1));
    box-shadow: 0 0 20px -4px var(--evl-glow, rgba(255,255,255,0.04));
}
.evl-tile::before {
    content: '';
    position: absolute;
    top: 12px; bottom: 12px; left: 0;
    width: 3px;
    border-radius: 0 3px 3px 0;
    background: var(--evl-accent, #33bdef);
    opacity: 0.5;
    transition: opacity 0.25s;
}
.evl-tile:hover::before { opacity: 0.9; }
.evl-tile-hook {
    font-size: 11px; font-weight: 500; color: rgba(255,255,255,0.35);
    margin-bottom: 6px; letter-spacing: 0.2px;
}
.evl-tile-headline {
    margin: 0 0 6px; font-size: 14px; font-weight: 600;
    color: rgba(255,255,255,0.88); line-height: 1.35;
}
.evl-tile-action {
    font-size: 12px; font-weight: 500; color: var(--evl-accent, #33bdef);
    display: inline-flex; align-items: center; gap: 4px;
    transition: gap 0.2s;
}
.evl-tile:hover .evl-tile-action { gap: 6px; }
.evl-tile-main {
    margin: 0 0 4px; font-size: 14px; font-weight: 600;
    color: rgba(255,255,255,0.88); line-height: 1.35;
}
.evl-tile-sub {
    font-size: 12px; color: rgba(255,255,255,0.4);
    margin-bottom: 8px; line-height: 1.4;
}
.evl-tile-cta {
    font-size: 11px; font-weight: 600; color: var(--evl-accent, #33bdef);
    display: inline-flex; align-items: center; gap: 4px;
    transition: gap 0.2s;
}
.evl-tile:hover .evl-tile-cta { gap: 6px; }
.evl-tile-footer {
    display: flex; align-items: center; justify-content: space-between;
    margin-top: 10px; padding-top: 8px;
    border-top: 1px solid rgba(255,255,255,0.04);
}
.evl-tile-disclosure {
    font-size: 10px; color: rgba(255,255,255,0.2);
    font-weight: 500; letter-spacing: 0.3px;
}
.evl-tile-proof {
    font-size: 10px; color: rgba(255,255,255,0.2); font-style: italic;
}
</style>

<script>
document.addEventListener('DOMContentLoaded', function() {
    const API_BASE = 'https://cooperative-renewal-production-41ce.up.railway.app';

    const HOOKS = [
        'Most creators get this wrong',
        'This might be why it\'s not working',
        'You\'re probably skipping this step',
        'The part nobody talks about',
        'Worth reading before your next post',
        'This changes how you think about growth'
    ];

    function genHook(t) { return HOOKS[(t||'').length % HOOKS.length]; }

    function genHeadline(t) {
        if (!t || t.length <= 50) return t || '';
        const l = t.toLowerCase();
        if (l.includes('youtube')) return 'Your YouTube strategy needs this update';
        if (l.includes('tiktok')) return 'TikTok growth isn\'t what you think it is';
        if (l.includes('instagram')) return 'Instagram changed the rules again';
        if (l.includes('twitter') || l.includes(' x ')) return 'Your tweets aren\'t the problem — this is';
        if (l.includes('caption')) return 'Your captions aren\'t the problem — this is';
        if (l.includes('seo')) return 'SEO basics most people still get wrong';
        if (l.includes('ai')) return 'How creators are actually using AI right now';
        if (l.includes('grow')) return 'The growth lever most people ignore';
        if (l.includes('monetiz')) return 'The monetization mistake you\'re probably making';
        if (l.includes('algorithm')) return 'What the algorithm actually rewards now';
        if (l.includes('content')) return 'This content approach changes everything';
        if (l.includes('brand')) return 'Your brand strategy is missing this';
        if (l.includes('engagement')) return 'Why your engagement dropped (and how to fix it)';
        return t.length > 55 ? t.slice(0, 52) + '...' : t;
    }

    const BUILT_IN = [
        { format:'utility', main:'Add a full economy system to your Discord', sub:'Shops, rewards, tasks — completely free', cta:'Add bot', proof:'Free for all servers', url:'https://evolvedlotus.github.io/EVLDiscordBot/', color:'#5865F2' },
        { format:'utility', main:'Turn your Telegram channel into income', sub:'All-in-one monetization — no setup hassle', cta:'Start now', proof:'Built for creators', url:'https://monetifygram.biz/', color:'#3b82f6' },
        { format:'insight', hook:'Spending hours on replies?', headline:'AI tools that actually save you time', action:'See tools', proof:'Used by content creators daily', url:'https://tools.evolvedlotus.com/', color:'#1DA1F2' }
    ];

    // Blog context: prioritize tools, discord, monetifygram — but 50% chance blog post
    const PRIORITY = ['tools', 'discord', 'monetifygram'];

    function buildTile(ad) {
        const c = ad.color || '#33bdef';
        let inner = '';
        if (ad.format === 'insight') {
            inner = `
                <div class="evl-tile-hook">${ad.hook}</div>
                <h4 class="evl-tile-headline">${ad.headline}</h4>
                <span class="evl-tile-action">${ad.action || 'Read this'} <span style="font-size:11px">→</span></span>`;
        } else {
            inner = `
                <h4 class="evl-tile-main">${ad.main}</h4>
                <div class="evl-tile-sub">${ad.sub}</div>
                <span class="evl-tile-cta">${ad.cta} <span style="font-size:11px">→</span></span>`;
        }
        return `<div class="evl-tile" style="--evl-accent:${c};--evl-glow:${c}18" data-url="${ad.url}" data-id="${ad.id||''}">
            ${inner}
            <div class="evl-tile-footer">
                <span class="evl-tile-disclosure">EvolvedLotus Ad</span>
                ${ad.proof ? `<span class="evl-tile-proof">${ad.proof}</span>` : ''}
            </div>
        </div>`;
    }

    const instances = document.querySelectorAll('.evl-ad-instance');
    if (!instances.length) return;

    // Try to get a blog ad from API
    fetch(`${API_BASE}/api/ad?client_id=blog&include_blogs=true`)
        .then(r => r.json())
        .then(data => {
            instances.forEach(inst => {
                const wrap = inst.querySelector('.evl-tile-wrap');
                let ad;

                // 50% blog from API, 50% built-in (rotated by instance index)
                if (data && !data.error && (data.type === 'rotating_blog' || data.type === 'blog') && Math.random() < 0.5) {
                    ad = {
                        format: 'insight',
                        hook: genHook(data.title || data.headline),
                        headline: genHeadline(data.headline || data.title),
                        action: 'Read this',
                        proof: 'Updated recently',
                        url: data.url,
                        color: data.color || '#33bdef',
                        id: data.id
                    };
                } else {
                    // Pick built-in deterministically based on position in DOM
                    const idx = Array.from(instances).indexOf(inst) % BUILT_IN.length;
                    ad = BUILT_IN[idx];
                }

                wrap.innerHTML = buildTile(ad);
                // Click handler
                wrap.querySelector('.evl-tile').addEventListener('click', function() {
                    const id = this.dataset.id;
                    const url = this.dataset.url;
                    if (id && !isNaN(id)) {
                        window.open(`${API_BASE}/api/click/${id}`, '_blank');
                    } else {
                        window.open(url, '_blank');
                    }
                });
                inst.style.display = 'block';
            });
        })
        .catch(() => {
            // API failed — use built-ins only
            instances.forEach((inst, i) => {
                const wrap = inst.querySelector('.evl-tile-wrap');
                const ad = BUILT_IN[i % BUILT_IN.length];
                wrap.innerHTML = buildTile(ad);
                wrap.querySelector('.evl-tile').addEventListener('click', function() {
                    window.open(this.dataset.url, '_blank');
                });
                inst.style.display = 'block';
            });
        });
});
</script>
{% set evlAdScriptLoaded = true %}
{% endif %}
